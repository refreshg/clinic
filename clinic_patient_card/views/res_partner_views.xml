<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Contact form: patient header (always visible) + Patient Card  -->
    <!-- as the FIRST tab                                              -->
    <!-- ============================================================ -->
    <record id="view_partner_form_patient_card" model="ir.ui.view">
        <field name="name">res.partner.form.patient.card</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Remove the standard Tax ID from its default spot; re-added in
                 the header below as the personal number (single field). -->
            <xpath expr="//field[@name='vat']" position="replace"/>

            <!-- The base "Contacts & Addresses" page is autofocused by default;
                 drop it so only the Patient Card page opens by default. -->
            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="autofocus"/>
            </xpath>

            <!-- Header block: Personal No. (vat), birthdate, age, gender +
                 patient toggle. Always visible, even for non-patients. -->
            <xpath expr="//notebook" position="before">
                <group>
                    <group>
                        <field name="vat" string="Personal No." placeholder=""/>
                        <field name="birthdate"/>
                        <field name="age"/>
                        <field name="gender"/>
                    </group>
                    <group>
                        <field name="is_patient"/>
                        <field name="patient_ref" invisible="not is_patient"/>
                    </group>
                </group>
            </xpath>

            <!-- Patient Card page inserted BEFORE the first existing tab -->
            <xpath expr="//notebook/page[1]" position="before">
                <page name="patient_card" string="Patient Card"
                      autofocus="autofocus"
                      invisible="not is_patient">

                    <!-- 1.9 Quick actions (placeholder buttons for now) -->
                    <div class="d-flex flex-wrap gap-1 mb-3" name="quick_actions">
                        <button name="action_clinic_todo" type="object"
                                string="Create Booking" class="btn-primary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Add Note" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Send Reminder" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Open Oral Chart" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Create Invoice" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Generate Form-100" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Sync EHR" class="btn-secondary"/>
                        <button name="action_clinic_todo" type="object"
                                string="Make Payment / To Debt" class="btn-secondary"/>
                    </div>

                    <!-- 1.1 Basic information (patient-specific) -->
                    <group string="Basic Information">
                        <group>
                            <field name="name_latin" invisible="not is_foreign"/>
                            <field name="registration_date"/>
                            <field name="referral_source"/>
                            <field name="referral_source_other"
                                   invisible="referral_source != 'other'"/>
                        </group>
                        <group>
                            <field name="is_foreign"/>
                            <field name="nationality_country_id" invisible="not is_foreign"/>
                            <field name="is_first_visit"/>
                        </group>
                    </group>

                    <!-- 1.2 Contact information -->
                    <group string="Contact Information">
                        <field name="patient_phone_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="phone"/>
                                <field name="phone_type"/>
                                <field name="channel"/>
                                <field name="owner_name"/>
                                <field name="is_emergency"/>
                                <field name="relation"/>
                                <field name="is_foreign_number" optional="show"/>
                                <field name="note" optional="hide"/>
                            </list>
                        </field>
                    </group>

                    <!-- 1.3 Medical history -->
                    <group string="Medical History">
                        <field name="allergy_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="allergy_type"/>
                                <field name="name"/>
                                <field name="reaction"/>
                                <field name="severity"/>
                                <field name="note"/>
                            </list>
                        </field>
                        <group>
                            <field name="chronic_diseases"/>
                            <field name="current_medications"/>
                            <field name="is_pregnant" invisible="gender != 'female'"/>
                        </group>
                        <group>
                            <field name="has_bleeding_disorder"/>
                            <field name="has_cardio_risk"/>
                            <field name="medical_risk_notes"/>
                        </group>
                        <group string="Last Update" col="2">
                            <field name="medical_update_date"/>
                            <field name="medical_update_uid"/>
                        </group>
                    </group>

                    <!-- 1.4 Dental history -->
                    <group string="Dental History">
                        <group>
                            <field name="last_dental_visit_date"/>
                            <field name="treatment_plan_status"/>
                        </group>
                        <group>
                            <field name="has_bruxism"/>
                            <field name="periodontitis_risk"/>
                        </group>
                        <field name="dental_other_notes" colspan="2"/>
                        <separator string="Procedure History" colspan="2"/>
                        <field name="procedure_history_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="procedure_date"/>
                                <field name="name"/>
                                <field name="doctor_id"/>
                                <field name="tooth"/>
                                <field name="note"/>
                            </list>
                        </field>
                        <separator string="Dental Chart (FDI)" colspan="2"/>
                        <field name="odontogram_html" colspan="2" nolabel="1" readonly="1"/>
                        <field name="tooth_ids" colspan="2" nolabel="1">
                            <list editable="bottom">
                                <field name="tooth_number"/>
                                <field name="status"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </group>

                    <!-- 1.5 Financial status -->
                    <group string="Financial Status">
                        <group string="Balance">
                            <field name="credit" string="Receivable (debt)"/>
                            <field name="debit" string="Payable (advance)"/>
                            <field name="total_invoiced"/>
                            <field name="property_payment_term_id"/>
                            <field name="preferred_payment_method"/>
                        </group>
                        <group string="Discounts and Loyalty">
                            <field name="discount_percent"/>
                            <field name="discount_fixed"/>
                            <field name="loyalty_status"/>
                        </group>
                        <group string="Insurance">
                            <field name="insurance_provider"/>
                            <field name="insurance_policy_no"/>
                            <field name="insurance_valid_until"/>
                            <field name="insurance_notes"/>
                        </group>
                        <separator string="Invoices and Payments" colspan="2"/>
                        <field name="invoice_ids" colspan="2" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="invoice_date"/>
                                <field name="move_type"/>
                                <field name="amount_total"/>
                                <field name="payment_state"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </group>

                    <!-- 1.6 Documents -->
                    <group string="Documents">
                        <field name="document_ids" colspan="2" nolabel="1">
                            <list>
                                <field name="doc_type"/>
                                <field name="name"/>
                                <field name="date"/>
                                <field name="attachment" filename="filename" widget="binary"/>
                                <field name="filename" column_invisible="1"/>
                                <field name="note"/>
                            </list>
                            <form>
                                <group>
                                    <group>
                                        <field name="doc_type"/>
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="attachment" filename="filename" widget="binary"/>
                                        <field name="filename" invisible="1"/>
                                        <field name="note"/>
                                    </group>
                                </group>
                                <separator string="Signature"
                                           invisible="doc_type != 'consent'"/>
                                <field name="signature" widget="signature"
                                       invisible="doc_type != 'consent'"/>
                            </form>
                        </field>
                    </group>

                    <!-- 1.7 Patient profile -->
                    <group string="Patient Profile">
                        <group>
                            <field name="no_show_rate"/>
                            <field name="ltv_forecast"/>
                        </group>
                        <group>
                            <field name="risk_level"/>
                            <field name="risk_notes"/>
                        </group>
                    </group>

                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search: filter patients                                       -->
    <!-- ============================================================ -->
    <record id="view_res_partner_filter_patient" model="ir.ui.view">
        <field name="name">res.partner.search.patient</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="filter_is_patient" string="Patients"
                        domain="[('is_patient', '=', True)]"/>
            </xpath>
        </field>
    </record>

</odoo>
